# Basile v1 – Environment template
# Copy this file to .env (and optionally .env.development / .env.production).
# Never commit .env or any file containing real keys.

# ===== Frontend only (VITE_*) – use ANON key, never service role in browser =====
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# API base URL (dev: http://localhost:3001)
VITE_API_URL=http://localhost:3001

# ===== Backend only (server) – never expose these in the frontend =====
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>
